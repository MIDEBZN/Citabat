---
import Layout from '../layouts/Layout.astro';
import EmergencyBanner from '../components/EmergencyBanner.astro';

const communes = [
  'Namur Centre (5000)',
  'Bouge (5004)',
  'Jambes (5000)',
  'Erpent (5101)',
  'Salzinnes (5000)',
  'Saint-Servais (5002)',
  'Flawinne (5020)',
  'Beez (5000)',
  'Gembloux (5030)',
  'Andenne (5300)',
  'Autre commune de la province'
];
---

<Layout
  title="Contact & Devis Gratuit - Citabat Plomberie Namur"
  description="Contactez Citabat pour une urgence plomberie à Namur ou pour obtenir un devis gratuit et sans engagement. Hotline 24h/24 & 7j/7 au 0480 14 75 76."
>
  <!-- Hero Header -->
  <section class="contact-hero">
    <div class="container text-center">
      <span class="badge badge-cyan">À Votre Écoute 24/7</span>
      <h1>Contactez Citabat à Namur</h1>
      <p class="hero-desc">
        Une urgence plomberie ou un projet d'installation ? Remplissez notre formulaire ci-dessous ou appelez directement notre permanence téléphonique.
      </p>
    </div>
  </section>

  <!-- Form & Contact Info -->
  <section class="section-padding">
    <div class="container grid-2 contact-grid">
      <!-- Contact Details & Hotline Card -->
      <div class="contact-info-wrapper">
        <div class="card emergency-contact-card">
          <span class="badge badge-orange">🚨 Hotline Urgence 24h/24 & 7j/7</span>
          <h2>Intervention Rapide à Namur</h2>
          <p>Pour un dépannage immédiat (fuite d'eau critique, débouchage urgent, chaudière à l'arrêt en hiver), privilégiez l'appel direct :</p>
          
          <a href="tel:0480147576" class="btn btn-emergency btn-lg w-full">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            0480 14 75 76
          </a>
          <span class="sub-guarantee">✓ Arrivée garantie en 30 min sur le grand Namur</span>
        </div>

        <div class="card info-details-card">
          <h3>Coordonnées & Informations Légales</h3>
          <ul class="info-list">
            <li>
              <div class="info-icon">📍</div>
              <div>
                <strong>Adresse des bureaux</strong>
                <p>Rue de Balart 87, 5004 Namur, Belgique</p>
              </div>
            </li>
            <li>
              <div class="info-icon">✉️</div>
              <div>
                <strong>Adresse E-mail</strong>
                <p><a href="mailto:contact@citabat.site">contact@citabat.site</a></p>
              </div>
            </li>
            <li>
              <div class="info-icon">📄</div>
              <div>
                <strong>Numéro de TVA</strong>
                <p>BE0783224718</p>
              </div>
            </li>
            <li>
              <div class="info-icon">🕒</div>
              <div>
                <strong>Horaires d'ouverture</strong>
                <p>Urgence Plomberie: 24h/24 - 7j/7<br />Bureaux & Devis: Lun - Sam: 07h30 - 19h00</p>
              </div>
            </li>
          </ul>
        </div>
      </div>

      <!-- Main Contact & Quote Form -->
      <div class="card form-card">
        <div class="form-title">
          <h2>Demande de Devis ou Rendez-vous</h2>
          <p>Devis gratuit et réponse garantie sous 15 minutes pendant les heures de bureau.</p>
        </div>

        <form class="main-form" id="contactForm">
          <div class="form-row">
            <div class="form-group">
              <label for="fullName">Nom & Prénom *</label>
              <input type="text" id="fullName" required placeholder="Ex: Pierre Dubois" />
            </div>
            <div class="form-group">
              <label for="email">Adresse E-mail *</label>
              <input type="email" id="email" required placeholder="Ex: pierre@example.be" />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="phoneNum">Numéro de Téléphone *</label>
              <input type="tel" id="phoneNum" required placeholder="Ex: 0480 14 75 76" />
            </div>
            <div class="form-group">
              <label for="commune">Commune d'Intervention</label>
              <select id="commune">
                {communes.map((c) => (
                  <option value={c}>{c}</option>
                ))}
              </select>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="category">Type de Service</label>
              <select id="category">
                <option value="depannage">🚨 Dépannage d'urgence</option>
                <option value="fuite">💧 Recherche / Réparation de fuite</option>
                <option value="debouchage">🚽 Débouchage canalisation / WC</option>
                <option value="chauffage">🔥 Entretien / Panne Chaudière</option>
                <option value="salle-de-bain">🛁 Rénovation Salle de Bain</option>
                <option value="autre">🔧 Autre installation sanitaire</option>
              </select>
            </div>
            <div class="form-group">
              <label for="urgency">Urgence du besoin</label>
              <select id="urgency">
                <option value="immediate">⚡ Urgent (dans l'heure)</option>
                <option value="24h">⏱️ Dans les 24h</option>
                <option value="semaine">📅 Dans la semaine</option>
                <option value="projet">💡 Projet futur (devis)</option>
              </select>
            </div>
          </div>

          <div class="form-group">
            <label for="message">Description de votre demande *</label>
            <textarea id="message" rows="4" required placeholder="Précisez votre problème ou les détails de votre projet..."></textarea>
          </div>

          <button type="submit" class="btn btn-primary btn-lg w-full">
            Envoyer ma Demande de Devis
          </button>
          
          <span class="privacy-notice">🔒 Vos données personnelles sont protégées et ne seront jamais revendues. (Citabat BE0783224718)</span>
        </form>
      </div>
    </div>
  </section>

  <!-- Emergency Banner -->
  <EmergencyBanner />
</Layout>

<style>
  .contact-hero {
    padding: 5rem 0 3rem 0;
    background: radial-gradient(circle at 50% 0%, #0d2342 0%, var(--bg-dark) 80%);
    border-bottom: 1px solid var(--border-light);
  }

  .text-center {
    text-align: center;
    max-width: 750px;
    margin: 0 auto;
  }

  .contact-hero h1 {
    font-size: 2.8rem;
    margin: 1rem 0;
  }

  .hero-desc {
    color: var(--text-muted);
    font-size: 1.15rem;
    line-height: 1.7;
  }

  .contact-grid {
    align-items: flex-start;
  }

  .contact-info-wrapper {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .emergency-contact-card {
    background: linear-gradient(135deg, rgba(255, 107, 53, 0.15) 0%, rgba(15, 28, 48, 0.95) 100%);
    border: 1px solid rgba(255, 107, 53, 0.4);
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .emergency-contact-card h2 {
    font-size: 1.8rem;
  }

  .emergency-contact-card p {
    color: var(--text-muted);
    font-size: 0.98rem;
  }

  .btn-lg {
    padding: 1.1rem 2rem;
    font-size: 1.15rem;
  }

  .sub-guarantee {
    font-size: 0.85rem;
    color: var(--cyan);
    text-align: center;
  }

  .info-details-card h3 {
    font-size: 1.3rem;
    margin-bottom: 1.2rem;
    border-bottom: 1px solid var(--border-light);
    padding-bottom: 0.6rem;
  }

  .info-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .info-list li {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .info-icon {
    font-size: 1.5rem;
    background: rgba(0, 210, 255, 0.1);
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .info-list strong {
    color: #ffffff;
    font-size: 0.95rem;
    display: block;
    margin-bottom: 0.2rem;
  }

  .info-list p, .info-list a {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .info-list a:hover {
    color: var(--cyan);
  }

  /* Form Card */
  .form-card {
    border-color: var(--border-active);
  }

  .form-title h2 {
    font-size: 2rem;
    margin-bottom: 0.4rem;
  }

  .form-title p {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-bottom: 1.8rem;
  }

  .main-form {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-muted);
  }

  .form-group input, .form-group select, .form-group textarea {
    background: rgba(7, 13, 25, 0.8);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-sm);
    padding: 0.85rem 1rem;
    color: #ffffff;
    font-family: var(--font-primary);
    font-size: 0.95rem;
    transition: var(--transition);
  }

  .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
    outline: none;
    border-color: var(--cyan);
    box-shadow: 0 0 10px var(--cyan-glow);
  }

  .privacy-notice {
    font-size: 0.8rem;
    color: var(--text-dim);
    text-align: center;
    margin-top: 0.5rem;
  }

  @media (max-width: 992px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const contactForm = document.getElementById('contactForm');
  if (contactForm) {
    contactForm.addEventListener('submit', (e) => {
      e.preventDefault();
      alert('Votre demande de devis a été transmise à l\'équipe Citabat ! Nous vous contacterons sous 15 minutes.');
      (contactForm as HTMLFormElement).reset();
    });
  }
</script>
