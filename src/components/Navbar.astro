---
const pathname = new URL(Astro.request.url).pathname;

const navLinks = [
  { name: 'Accueil', href: '/' },
  { name: 'Services', href: '/services' },
  { name: 'Zones d\'intervention', href: '/locations' },
  { name: 'À Propos', href: '/about' },
  { name: 'Contact & Devis', href: '/contact' },
];
---

<header class="navbar-header">
  <div class="navbar-top-bar">
    <div class="container top-bar-content">
      <div class="top-info">
        <span>📍 Intervention rapide à Namur et toute la province</span>
        <span>⏱️ Urgence 24h/24 & 7j/7 en 30 min</span>
      </div>
      <div class="top-contact">
        <a href="tel:081394820" class="top-phone">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          <span>Appel d'urgence: <strong>081 39 48 20</strong></span>
        </a>
      </div>
    </div>
  </div>

  <nav class="main-nav">
    <div class="container nav-container">
      <a href="/" class="brand-logo">
        <div class="logo-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"></path></svg>
        </div>
        <div class="logo-text">
          <span class="brand-name">CITABAT</span>
          <span class="brand-sub">Plomberie Namur</span>
        </div>
      </a>

      <ul class="nav-links">
        {navLinks.map((link) => {
          const isActive = pathname === link.href || (link.href !== '/' && pathname.startsWith(link.href));
          return (
            <li>
              <a href={link.href} class={isActive ? 'nav-link active' : 'nav-link'}>
                {link.name}
              </a>
            </li>
          );
        })}
      </ul>

      <div class="nav-actions">
        <a href="tel:081394820" class="btn btn-emergency">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          081 39 48 20
        </a>

        <button class="mobile-toggle" id="mobileToggle" aria-label="Menu principal">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </div>

    <div class="mobile-menu" id="mobileMenu">
      <ul class="mobile-nav-links">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class="mobile-link">
              {link.name}
            </a>
          </li>
        ))}
        <li class="mobile-cta">
          <a href="tel:081394820" class="btn btn-emergency w-full">
            📞 Urgence 081 39 48 20
          </a>
        </li>
      </ul>
    </div>
  </nav>
</header>

<style>
  .navbar-header {
    position: sticky;
    top: 0;
    z-index: 1000;
    width: 100%;
    background: rgba(7, 13, 25, 0.9);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border-light);
  }

  .navbar-top-bar {
    background: rgba(0, 119, 255, 0.12);
    border-bottom: 1px solid rgba(0, 210, 255, 0.1);
    font-size: 0.82rem;
    padding: 0.4rem 0;
    color: var(--text-muted);
  }

  .top-bar-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .top-info {
    display: flex;
    gap: 1.5rem;
  }

  .top-phone {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--cyan);
    font-weight: 600;
  }

  .main-nav {
    padding: 0.9rem 0;
    position: relative;
  }

  .nav-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .brand-logo {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .logo-icon {
    width: 44px;
    height: 44px;
    background: linear-gradient(135deg, var(--primary) 0%, var(--cyan) 100%);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    box-shadow: 0 4px 14px var(--primary-glow);
  }

  .logo-text {
    display: flex;
    flex-direction: column;
  }

  .brand-name {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: 1px;
    color: #ffffff;
    line-height: 1;
  }

  .brand-sub {
    font-size: 0.75rem;
    color: var(--cyan);
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 2rem;
  }

  .nav-link {
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--text-muted);
    padding: 0.5rem 0;
    position: relative;
  }

  .nav-link:hover, .nav-link.active {
    color: #ffffff;
  }

  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg, var(--primary), var(--cyan));
    border-radius: 2px;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 5px;
  }

  .mobile-toggle span {
    width: 24px;
    height: 2px;
    background-color: #ffffff;
    transition: var(--transition);
  }

  .mobile-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background: var(--bg-card);
    border-bottom: 1px solid var(--border-light);
    padding: 1.5rem;
    box-shadow: var(--shadow-lg);
  }

  .mobile-menu.open {
    display: block;
  }

  .mobile-nav-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .mobile-link {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-main);
    display: block;
    padding: 0.5rem 0;
  }

  .mobile-cta {
    margin-top: 1rem;
  }

  .w-full {
    width: 100%;
  }

  @media (max-width: 992px) {
    .top-info {
      display: none;
    }
    .top-bar-content {
      justify-content: center;
    }
    .nav-links {
      display: none;
    }
    .mobile-toggle {
      display: flex;
    }
  }
</style>

<script>
  const toggleBtn = document.getElementById('mobileToggle');
  const mobileMenu = document.getElementById('mobileMenu');

  if (toggleBtn && mobileMenu) {
    toggleBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('open');
    });
  }
</script>
